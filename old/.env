# LLM API Configuration
LLM_API_BASE_URL=http://192.168.1.69:1234/v1
LLM_API_KEY=not-needed  # LMStudio doesn't require an API key, but other services might
LLM_MODEL=trinity-2-codestral-22b-v0.2  # The model to use
LLM_MAX_TOKENS=1000  # Maximum number of tokens in the response
LLM_TEMPERATURE=0.7  # Controls randomness (0.0 - 1.0)

# Neo4j Configuration
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Milvus Configuration
MILVUS_HOST=milvus
MILVUS_PORT=19530